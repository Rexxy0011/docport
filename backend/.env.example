# MongoDB connection string (e.g. mongodb+srv://user:pass@cluster.mongodb.net)
MONGODB_URI=

# Secret used to sign JWTs. Keep long and random.
JWT_SECRET=

# Admin credentials. These are checked verbatim by loginAdmin.
ADMIN_EMAIL=
ADMIN_PASSWORD=

# Cloudinary credentials for image uploads.
CLOUDINARY_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_SECRET_KEY=

# Paystack secret key (sk_test_... for test mode).
PAYSTACK_SECRET_KEY=

# Comma-separated list of allowed browser origins for CORS.
# Leave empty to allow all origins (dev only).
# e.g. CORS_ORIGINS=https://docport.vercel.app,https://docport-admin.vercel.app,http://localhost:5173
CORS_ORIGINS=

# URL Paystack redirects to after payment (reference query param attached).
PAYMENT_CALLBACK_URL=http://localhost:5173/payment-success

# Server port (optional, defaults to 4000).
PORT=4000
